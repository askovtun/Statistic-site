# Jira Insight (on-premises, Data Center)
JIRA_URL=https://jira.epicentrk.ua
JIRA_USER=admin
JIRA_PASSWORD=secret
JIRA_SCHEMA_ID=41
JIRA_VM_TYPE_ID=1439
JIRA_CLUSTER_TYPE_ID=1438
JIRA_OS_TYPE_ID=1445

# Zabbix
ZABBIX_URL=https://zabbix.epicentrk.ua
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix
# API token (Zabbix 5.4+) — якщо вказано, user/password ігноруються
# ZABBIX_API_TOKEN=your_token_here

# Аналіз
METRICS_PERIOD_DAYS=30
CPU_OVERSIZED_THRESHOLD=20
CPU_UNDERSIZED_THRESHOLD=80
RAM_OVERSIZED_THRESHOLD=40
RAM_UNDERSIZED_THRESHOLD=85
CLUSTER_SPLIT_THRESHOLD=30

# HTTP
SSL_VERIFY=true
REQUEST_DELAY=0.3
REQUEST_RETRIES=3

# CORS — через кому, вкажіть URL IIS сайту
# Приклад: CORS_ORIGINS=http://server.domain.ua,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
